<Project Sdk="Microsoft.NET.Sdk">

  <!-- Hamon コア：宣言的reactive UIライブラリ。エンジン非依存（純粋C#・MonoGame 参照なし）。
       描画/テキスト/テクスチャは IPainter / ITextRenderer / ITexture の抽象越し。
       具体バックエンドは Hamon.MonoGame 等が提供する。 -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Hamon</RootNamespace>
    <IsPackable>true</IsPackable>
    <PackageId>Hamon</PackageId>
    <Description>Engine-independent reactive, declarative UI core for C#.</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Hamon.Tests" />
  </ItemGroup>

</Project>
